#Область ОбработчикиСобытийФормы   

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЗапрещенныеПоля = Новый Массив; 
	ЗапрещенныеПоля.Добавить("Ключ");  
	ЗапрещенныеПоля.Добавить("Значение1");
	ЗапрещенныеПоля.Добавить("Значение2");
	ЗапрещенныеПоля.Добавить("Значение3");
	ЗапрещенныеПоля.Добавить("Значение4");
	ЗапрещенныеПоля.Добавить("Значение5");  	
	
	Список.УстановитьОграниченияИспользованияВОтборе(ЗапрещенныеПоля); 
	Список.УстановитьОграниченияИспользованияВГруппировке(ЗапрещенныеПоля);
	Список.УстановитьОграниченияИспользованияВПорядке(ЗапрещенныеПоля);	
	
КонецПроцедуры 

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура РазделОтборПриИзменении(Элемент)
	
	ПараметрыРаздела 	= Неопределено;
	Секция 				= Неопределено;
	ПолеВводаСекция 	= Элементы.СекцияОтбор;
	ПолеВводаСекция.СписокВыбора.Очистить();
	ПолеВводаСекция.Видимость = Ложь;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "Секция", Неопределено,,, Ложь);
	
	Если ЗначениеЗаполнено(Раздел) Тогда   	
		
		ПараметрыРаздела = ПолучиьПараметрыРаздела(Раздел);
		Если ПараметрыРаздела.ИспользоватьСекцииРаздела Тогда
			ПолеВводаСекция.СписокВыбора.ЗагрузитьЗначения(ПараметрыРаздела.Секции);  
			ПолеВводаСекция.Видимость = Истина;	
		КонецЕсли;  
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "Раздел", Раздел,,, Истина); 		
		
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "Раздел", Неопределено,,, Ложь);   	
	КонецЕсли;  
	
	УстановитьВидимостьКолонок(ПараметрыРаздела);
	
КонецПроцедуры

&НаКлиенте
Процедура СекцияОтборПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Секция) Тогда 
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "Секция", Секция,,, Истина);		
	Иначе    	
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "Секция", Неопределено,,, Ложь);
	КонецЕсли;		
	
КонецПроцедуры  

#КонецОбласти

#Область ОбработчикиКоманд

&НаКлиенте
Процедура СоздатьНастройкуРаздела(Команда)
	
	ПараметрыОткрытия = Новый Структура("Раздел, Секция", Раздел, Секция);
	
	ОткрытьФорму("РегистрСведений.рнсОбщиеНастройки.Форма.ФормаЗаписи", ПараметрыОткрытия, ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФлажки(Команда)
	УстановитьЗначениеФлажка(Истина);	
КонецПроцедуры

&НаКлиенте
Процедура СнятьФлажки(Команда)   	
	УстановитьЗначениеФлажка(Ложь);	
КонецПроцедуры

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции   

&НаКлиенте
Процедура УстановитьЗначениеФлажка(Флаг)
	
	УстановитьФлагОтключитьНаСервере(Флаг);
	Элементы.Список.Обновить();
	
КонецПроцедуры    

&НаСервереБезКонтекста
Функция ПолучиьПараметрыРаздела(Раздел) 
	          
	Результат = Новый Структура("ИспользоватьСекцииРаздела, ИспользоватьКлючНастройки, Секции,
									| Заголовок1, Заголовок2, Заголовок3, Заголовок4, Заголовок5");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рнсРазделыОбщихНастроек.ИспользоватьСекцииРаздела КАК ИспользоватьСекцииРаздела,
		|	рнсРазделыОбщихНастроек.ИспользоватьКлючНастройки КАК ИспользоватьКлючНастройки,
		|	ЕСТЬNULL(рнсРазделыОбщихНастроек.ТипЗначения1.Заголовок, НЕОПРЕДЕЛЕНО) КАК Заголовок1,
		|	ЕСТЬNULL(рнсРазделыОбщихНастроек.ТипЗначения2.Заголовок, НЕОПРЕДЕЛЕНО) КАК Заголовок2,
		|	ЕСТЬNULL(рнсРазделыОбщихНастроек.ТипЗначения3.Заголовок, НЕОПРЕДЕЛЕНО) КАК Заголовок3,
		|	ЕСТЬNULL(рнсРазделыОбщихНастроек.ТипЗначения4.Заголовок, НЕОПРЕДЕЛЕНО) КАК Заголовок4,
		|	ЕСТЬNULL(рнсРазделыОбщихНастроек.ТипЗначения5.Заголовок, НЕОПРЕДЕЛЕНО) КАК Заголовок5
		|ИЗ
		|	Справочник.рнсРазделыОбщихНастроек КАК рнсРазделыОбщихНастроек
		|ГДЕ
		|	рнсРазделыОбщихНастроек.Ссылка = &Раздел
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Таблица.Секция КАК Секция
		|ИЗ
		|	Справочник.рнсРазделыОбщихНастроек.Секции КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &Раздел";
	
	Запрос.УстановитьПараметр("Раздел", Раздел);
	
	РезультатЗапроса 		= Запрос.ВыполнитьПакет();  
	ВыборкаШапка 			= РезультатЗапроса[0].Выбрать();
	Секции					= РезультатЗапроса[1].Выгрузить().ВыгрузитьКолонку("Секция");
	
	Пока ВыборкаШапка.Следующий() Цикл 	
		ЗаполнитьЗначенияСвойств(Результат, ВыборкаШапка);	
		Результат.Секции = Секции;  	
	КонецЦикла; 
	
	Возврат Результат;
	
КонецФункции    

&НаСервере
Процедура УстановитьФлагОтключитьНаСервере(Флаг)

	Для каждого Ит Из Элементы.Список.ВыделенныеСтроки Цикл
		
		Запись = РегистрыСведений.рнсОбщиеНастройки.СоздатьМенеджерЗаписи();  
		ЗаполнитьЗначенияСвойств(Запись, Ит);
		Запись.Прочитать();
		
		Если Запись.Выбран() Тогда  
			Запись.Отключено = Флаг;
			Запись.Записать();	
		КонецЕсли;
		
	КонецЦикла;	
	
КонецПроцедуры 

&НаКлиенте
Процедура УстановитьВидимостьКолонок(ПараметрыРаздела)
	
	Если ПараметрыРаздела = Неопределено Тогда 	
		
		Элементы.Секция.Видимость 	= Истина; 
		Элементы.Ключ.Видимость 	= Ложь;
		
		Элементы.Значение1.Видимость = Истина; 
		Элементы.Значение2.Видимость = Истина;
		Элементы.Значение3.Видимость = Истина;
		Элементы.Значение4.Видимость = Истина;
		Элементы.Значение5.Видимость = Истина;
		
		Элементы.Значение1.Заголовок = НСтр("ru = 'Значение 1'"); 
		Элементы.Значение2.Заголовок = НСтр("ru = 'Значение 2'");
		Элементы.Значение3.Заголовок = НСтр("ru = 'Значение 3'");
		Элементы.Значение4.Заголовок = НСтр("ru = 'Значение 4'");
		Элементы.Значение5.Заголовок = НСтр("ru = 'Значение 5'");	
		
	Иначе  		
		
		Элементы.Секция.Видимость 	= ПараметрыРаздела.ИспользоватьСекцииРаздела; 
		Элементы.Ключ.Видимость 	= ПараметрыРаздела.ИспользоватьКлючНастройки; 			
		
		Элементы.Значение1.Видимость = ПараметрыРаздела.Заголовок1 <> Неопределено; 
		Элементы.Значение2.Видимость = ПараметрыРаздела.Заголовок2 <> Неопределено;
		Элементы.Значение3.Видимость = ПараметрыРаздела.Заголовок3 <> Неопределено;
		Элементы.Значение4.Видимость = ПараметрыРаздела.Заголовок4 <> Неопределено;
		Элементы.Значение5.Видимость = ПараметрыРаздела.Заголовок5 <> Неопределено;
		
		Элементы.Значение1.Заголовок = ?(ЗначениеЗаполнено(ПараметрыРаздела.Заголовок1), ПараметрыРаздела.Заголовок1, НСтр("ru = 'Значение 1'")); 
		Элементы.Значение2.Заголовок = ?(ЗначениеЗаполнено(ПараметрыРаздела.Заголовок2), ПараметрыРаздела.Заголовок2, НСтр("ru = 'Значение 2'"));
		Элементы.Значение3.Заголовок = ?(ЗначениеЗаполнено(ПараметрыРаздела.Заголовок3), ПараметрыРаздела.Заголовок3, НСтр("ru = 'Значение 3'"));
		Элементы.Значение4.Заголовок = ?(ЗначениеЗаполнено(ПараметрыРаздела.Заголовок4), ПараметрыРаздела.Заголовок4, НСтр("ru = 'Значение 4'"));
		Элементы.Значение5.Заголовок = ?(ЗначениеЗаполнено(ПараметрыРаздела.Заголовок5), ПараметрыРаздела.Заголовок5, НСтр("ru = 'Значение 5'"));  	
		
	КонецЕсли;	
	
КонецПроцедуры  

#КонецОбласти  
