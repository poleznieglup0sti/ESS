#Область ОбработчикиФормы   

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	              	
	УстановитьПараметрыФункциональныхОпцийФормы(Новый Структура("рнсРаздел", Запись.Раздел));
	
	УстановитьНастройкиКолонок();
	       		
	ПодготовитьФормуПоРазделу(); 
	
КонецПроцедуры   

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	         	
	Если НЕ ЗначениеЗаполнено(Запись.Раздел) Тогда // по стандарту так
		Отказ = Истина;	
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ЭтоАдресВременногоХранилища(АдресХранилища) Тогда
		ТекущийОбъект.Настройки = Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(АдресХранилища));	
	КонецЕсли; 		
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиЭлементовФормы

&НаКлиенте
Процедура РазделПриИзменении(Элемент)
	
	УстановитьПараметрыФункциональныхОпцийФормы(Новый Структура("рнсРаздел", Запись.Раздел));
	
	УстановитьНастройкиКолонок();
	
	ПодготовитьФормуПоРазделу();
	
КонецПроцедуры

&НаКлиенте
Процедура НадписьОткрытьДополнительныеНастройкиНажатие(Элемент)
	
	Если ЗначениеЗаполнено(ИмяФормыДополнительныхНастроек) Тогда 
		
		ПараметрыФормы = Новый Структура;
		Для Сч = 1 По 5 Цикл
			ПараметрыФормы.Вставить("Значение" + Сч, Запись["Значение" + Сч]);	
		КонецЦикла; 		   
		
		ПараметрыФормы.Вставить("АдресХранилища", АдресХранилища);
		ПараметрыФормы.Вставить("Раздел", Запись.Раздел);
		ПараметрыФормы.Вставить("Секция", Запись.Секция);
		ПараметрыФормы.Вставить("Ключ", Запись.Ключ);
		
		ОткрытьФорму(ИмяФормыДополнительныхНастроек, ПараметрыФормы, 
						ЭтотОбъект,,,, Новый ОписаниеОповещения("ВводДополнительныхНастроек_Завершение", ЭтотОбъект));	
						
	КонецЕсли;		
	
КонецПроцедуры

#КонецОбласти 

#Область ПодключаемыеОбработчики

&НаКлиенте
Процедура ВводДополнительныхНастроек_Завершение(Результат, ДополнительныеНастройки) Экспорт
	
	Если Результат = Неопределено Тогда
		
		ПоместитьВоВременноеХранилище(Неопределено, АдресХранилища);
		
		ЗаголовокНадписи = НСтр("ru = 'Дополнительные настройки не заданы'");		
		
	Иначе
		
		Если ЭтоАдресВременногоХранилища(Результат) Тогда
			Если Результат <> АдресХранилища Тогда
				ПоместитьВоВременноеХранилище(Неопределено, АдресХранилища);
				АдресХранилища = Результат;	
			КонецЕсли;    			 			
		Иначе
			ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
		КонецЕсли;
		
		ЗаголовокНадписи = НСтр("ru = 'Дополнительные настройки заданы'");
		
	КонецЕсли; 	
	
	Элементы.НадписьОткрытьДополнительныеНастройки.Заголовок = ЗаголовокНадписи; 
	
КонецПроцедуры   

#КонецОбласти   

#Область СлужебныеПроцедурыИФункции   

&НаСервере
Процедура ПодготовитьФормуПоРазделу()
	
	Если ЗначениеЗаполнено(Запись.Раздел) Тогда
		
		ИмяФормыДополнительныхНастроек = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Запись.Раздел, "ИмяФормыЗаполненияХранилища");
		
		Если ЗначениеЗаполнено(ИмяФормыДополнительныхНастроек) Тогда
			
			Элементы.НадписьОткрытьДополнительныеНастройки.Доступность 	= Истина;
			ЗаписьОбъект 												= РеквизитФормыВЗначение("Запись");
			ЗначениеХранилища 											= ЗаписьОбъект.Настройки.Получить(); 		
			
			Если ЗначениеХранилища = Неопределено Тогда			
				Элементы.НадписьОткрытьДополнительныеНастройки.Заголовок = НСтр("ru = 'Расширенные настройки не заданы'");			
			Иначе
				Элементы.НадписьОткрытьДополнительныеНастройки.Заголовок = НСтр("ru = 'Расширенные настройки заданы'");			
			КонецЕсли;
			
			АдресХранилища = ПоместитьВоВременноеХранилище(ЗначениеХранилища, УникальныйИдентификатор);
			
		Иначе
			Элементы.НадписьОткрытьДополнительныеНастройки.Заголовок 	= НСтр("ru = 'Расширенные настройки раздела не предусмотрены'");
			Элементы.НадписьОткрытьДополнительныеНастройки.Доступность 	= Ложь;		
		КонецЕсли;
		
	КонецЕсли; 		
	
КонецПроцедуры  

&НаСервере
Процедура УстановитьНастройкиКолонок()
	
	Если ЗначениеЗаполнено(Запись.Раздел) Тогда 		
		
		СекцияСписокВыбора = Элементы.Секция.СписокВыбора;			
		
		СекцияСписокВыбора.Очистить();
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаРаздела.ТипЗначения1.ТипЗначения КАК Значение1,
		|	ТаблицаРаздела.ТипЗначения2.ТипЗначения КАК Значение2,
		|	ТаблицаРаздела.ТипЗначения3.ТипЗначения КАК Значение3,
		|	ТаблицаРаздела.ТипЗначения4.ТипЗначения КАК Значение4,
		|	ТаблицаРаздела.ТипЗначения5.ТипЗначения КАК Значение5,
		|	ТаблицаРаздела.ТипЗначения1.Заголовок КАК Заголовок1,
		|	ТаблицаРаздела.ТипЗначения2.Заголовок КАК Заголовок2,
		|	ТаблицаРаздела.ТипЗначения3.Заголовок КАК Заголовок3,
		|	ТаблицаРаздела.ТипЗначения4.Заголовок КАК Заголовок4,
		|	ТаблицаРаздела.ТипЗначения5.Заголовок КАК Заголовок5
		|ИЗ
		|	Справочник.рнсРазделыОбщихНастроек КАК ТаблицаРаздела
		|ГДЕ
		|	ТаблицаРаздела.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Таблица.Секция КАК Секция
		|ИЗ
		|	Справочник.рнсРазделыОбщихНастроек.Секции КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &Ссылка
		|	И Таблица.Ссылка.ИспользоватьСекцииРаздела";
		
		Запрос.УстановитьПараметр("Ссылка", Запись.Раздел);
		
		РезультатЗапроса 		= Запрос.ВыполнитьПакет();		
		ВыборкаТипыЗначений 	= РезультатЗапроса[0].Выбрать(); 
		ВыборкаСекции 			= РезультатЗапроса[1].Выбрать();		
		
		Если ВыборкаТипыЗначений.Следующий() Тогда
			Для НомерПоПорядку = 1 По 5 Цикл 			
				
				Имя			= "Значение" + НомерПоПорядку; 
				Заголовок 	= ВыборкаТипыЗначений["Заголовок" + НомерПоПорядку];
				ПолеВвода 	= Элементы[Имя];
				
				Если ЗначениеЗаполнено(ВыборкаТипыЗначений[Имя]) Тогда
					ПолеВвода.ОграничениеТипа 	= ВыборкаТипыЗначений[Имя];  
					ПолеВвода.Видимость 		= Истина;
					ПолеВвода.Заголовок 		= ?(ЗначениеЗаполнено(Заголовок), Заголовок, Имя);
				Иначе
					ПолеВвода.Видимость 		= Ложь;	
				КонецЕсли;   			
				
			КонецЦикла;  					
		КонецЕсли;	 
		
		Если ВыборкаСекции.Количество() = 0 Тогда 
			Элементы.Секция.Видимость = Ложь;	
		Иначе   
			
			Элементы.Секция.Видимость = Истина;
			
			Пока ВыборкаСекции.Следующий() Цикл
				СекцияСписокВыбора.Добавить(ВыборкаСекции.Секция);		  					
			КонецЦикла;	  
			
		КонецЕсли; 		    	
		
	КонецЕсли; 	
	
КонецПроцедуры

#КонецОбласти 


 









