// Преобразует произвольный объект в двоичные данные
//
// Параметры:
//  Объект				 - Произвольный	 - произвольный объект
//  ПараметрыКонвертации - Структура	 - дополнительные параметры
// 
// Возвращаемое значение:
//   - ДвоичныеДанные - двоичные данные объекта 
//
Функция ОбъектВДвоичныеДанные(Объект, ПараметрыКонвертации = Неопределено) Экспорт	
	                          	
	Поток = Новый ПотокВПамяти();
	
	Если ПараметрыКонвертации = Неопределено Тогда
		Объект.Записать(Поток);
	Иначе
		
		ТипОбъекта = ТипЗнч(Объект);
		
		Если ТипОбъекта = Тип("ТабличныйДокумент") Тогда
			Объект.Записать(Поток, ПараметрыКонвертации.ТипФайла);	
		КонецЕсли; 
		
	КонецЕсли;
	   
	Возврат Поток.ЗакрытьИПолучитьДвоичныеДанные();
	
КонецФункции

