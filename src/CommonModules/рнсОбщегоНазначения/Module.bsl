#Область XDTO

// Записывает объект XDTO в приемник
//
// Параметры:
//  ИсточникДанных	 - ОбъектXDTO	 - объект XDTO
//  Приемник		 - Строка,Поток	 - если строка то запись в файл, если поток, то запись в поток, если Неопределено, то в строку
//  Фабрика			 - ФабрикаXDTO	 - фабрика XDTO
//  ЭтоJSON			 - Булево	 - признак JSON сериализации 
//
Процедура ЗаписатьОбъектXDTO(ИсточникДанных, Приемник = Неопределено, Фабрика = Неопределено, ЭтоJSON = Ложь) Экспорт
	
	ТипПриемника = ТипЗнч(Приемник);	
	Запись		 = ?(ЭтоJSON, Новый ЗаписьJSON(), Новый ЗаписьXML());
	
	Если Фабрика = Неопределено Тогда
		Фабрика = ФабрикаXDTO;
	КонецЕсли;
	
	ИсточникДанных.Проверить();	 
	
	Если Приемник = Неопределено ИЛИ Приемник = "" Тогда
		
		Запись.УстановитьСтроку();
		
		Если ЭтоJSON Тогда			
			Фабрика.ЗаписатьJSON(Запись, ИсточникДанных, НазначениеТипаXML.Явное);
		Иначе
			Фабрика.ЗаписатьXML(Запись, ИсточникДанных, , , , НазначениеТипаXML.Явное);
		КонецЕсли; 	
		
		Приемник = Запись.Закрыть();
		
	Иначе 				
		
		Если ТипПриемника = Тип("Поток") ИЛИ ТипПриемника = Тип("ПотокВПамяти") ИЛИ ТипПриемника = Тип("ФайловыйПоток") Тогда
			Запись.ОткрытьПоток(Приемник);			
		ИначеЕсли ТипПриемника = Тип("Строка") Тогда 
			Запись.ОткрытьФайл(Приемник);	
		Иначе                   
			ВызватьИсключение СтрШаблон(НСтр("ru='Приемник не определен %1'"), ТипПриемника);
		КонецЕсли;	
		
		Если ЭтоJSON Тогда			
			Фабрика.ЗаписатьJSON(Запись, ИсточникДанных, НазначениеТипаXML.Явное);
		Иначе
			Фабрика.ЗаписатьXML(Запись, ИсточникДанных, , , , НазначениеТипаXML.Явное);
		КонецЕсли;	
		
		Запись.Закрыть();
		
		Приемник.Перейти(0, ПозицияВПотоке.Начало);
		
	КонецЕсли;	  	
	    	
КонецПроцедуры 

// Читает объект XDTO 
//
// Параметры:
//  ИсточникДанных	 - Строка,Поток	 - источник для создания объекта XDTO
//  Фабрика			 - ФабрикаXDTO	 - фабрика XDTO
//  ЭтоJSON			 - Булево	 - признак JSON сериализации
// 
// Возвращаемое значение:
//   - ОбъектXDTO - объект
//
Функция ПрочитатьОбъектXDTO(ИсточникДанных, Фабрика = Неопределено, ЭтоJSON = Ложь) Экспорт
	
	Результат 		= Неопределено;
	ТипИсточника 	= ТипЗнч(ИсточникДанных);
	Чтение			= ?(ЭтоJSON, Новый ЧтениеJSON, Новый ЧтениеXML);
	
	Если Фабрика = Неопределено Тогда
		Фабрика = ФабрикаXDTO;
	КонецЕсли; 	 
	
	Если ТипИсточника = Тип("Поток") ИЛИ ТипИсточника = Тип("ПотокВПамяти") ИЛИ ТипИсточника = Тип("ФайловыйПоток") Тогда  		
		Чтение.ОткрытьПоток(ИсточникДанных);
	ИначеЕсли ТипИсточника = Тип("ДвоичныеДанные") Тогда  			
		Чтение.ОткрытьПоток(ИсточникДанных.ОткрытьПотокДляЧтения());	
	Иначе 		     
		Если НЕ ЭтоJSON И СтрНачинаетсяС(СокрЛ(ИсточникДанных), "<")
				ИЛИ ЭтоJSON И СтрНачинаетсяС(СокрЛ(ИсточникДанных), "{") Тогда 
			Чтение.УстановитьСтроку(ИсточникДанных);
		Иначе
			Чтение.ОткрытьФайл(ИсточникДанных);	
		КонецЕсли; 			
	КонецЕсли;  	
	
	Чтение.Прочитать();
	
	URIПространстваИмен = Чтение.URIПространстваИмен; 
	ИмяТипаXDTO 		= Чтение.Имя;
	ТипXDTO 			= Фабрика.Тип(URIПространстваИмен, ИмяТипаXDTO); 	
	
	Результат = Фабрика.ПрочитатьXML(Чтение, ТипXDTO);
	
	Чтение.Закрыть();
	
	Возврат Результат;
	
КонецФункции 

// Создает таблицу значений из СпискаXDTO
//
// Параметры:
//  КоллекцияXDTO	 - СписокXDTO	 - исходный список XDTO 
//  СтруктураЗамены	 - Структура	 - структура имен колонок 
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - таблица с колонка СпискаXDTO, если не указана замена имен
//
Функция СформироватьТаблицуИзКоллекцииXDTO(КоллекцияXDTO, СтруктураЗамены = Неопределено) Экспорт
	
	Результат = Новый ТаблицаЗначений;
	
	Если КоллекцияXDTO <> Неопределено Тогда  
		
		Если СтруктураЗамены = Неопределено Тогда
			
			ТипКоллекцииСтатусов = КоллекцияXDTO.ВладеющееСвойство.Тип;
			
			Для каждого Ит Из ТипКоллекцииСтатусов.Свойства Цикл
				Результат.Колонки.Добавить(Ит.Имя);	
			КонецЦикла;
			
			Для каждого СтрокаXDTO Из КоллекцияXDTO Цикл
				ЗаполнитьЗначенияСвойств(Результат.Добавить(), СтрокаXDTO);	
			КонецЦикла;
			
		Иначе
			
			Для каждого Ит Из СтруктураЗамены Цикл
				
				ОписаниеКолонки = Ит.Значение;
				
				Если ТипЗнч(ОписаниеКолонки) = Тип("Структура") Тогда
					Результат.Колонки.Добавить(ОписаниеКолонки.Имя, ОписаниеКолонки.Тип);		
				Иначе
					Результат.Колонки.Добавить(ОписаниеКолонки);
				КонецЕсли; 
				
			КонецЦикла; 
			
			Для каждого СтрокаXDTO Из КоллекцияXDTO Цикл
				
				НоваяСтрока = Результат.Добавить();
				
				Для каждого Ит Из СтруктураЗамены Цикл
					
					ОписаниеКолонки = Ит.Значение;
					
					Если ТипЗнч(ОписаниеКолонки) = Тип("Структура") Тогда
						НоваяСтрока[ОписаниеКолонки.Имя] = СтрокаXDTO[Ит.Ключ];		
					Иначе
						НоваяСтрока[ОписаниеКолонки] = СтрокаXDTO[Ит.Ключ];
					КонецЕсли; 
												
				КонецЦикла;   				
					
			КонецЦикла;
			
		КонецЕсли; 		 
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Создает дубликат объекта XDTO, копированием свойств
//
// Параметры:
//  ИсточникXDTO 	- ОбъектXDTO	- объект XDTO
//  Ключ	 		- Булево	 	- имя поля XDTO для копирования 
// 
// Возвращаемое значение:
//   - ОбъектXDTO - копия исходного объекта
//
Функция СкопироватьОбъектXDTO(ИсточникXDTO, Ключ = "") Экспорт
	
	Результат = Неопределено; 	
	
	Если ИсточникXDTO <> Неопределено Тогда
		
		ТипXDTO 			= ИсточникXDTO.Тип();
		Результат 			= ФабрикаXDTO.Создать(ТипXDTO);		
		
		Если ЗначениеЗаполнено(Ключ) Тогда
			СвойствоКлюча = ТипXDTO.Свойства.Получить(Ключ);
			Если СвойствоКлюча = Неопределено Тогда
				СвойстваИсточника = ТипXDTO.Свойства;
			Иначе
				СвойстваИсточника = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(СвойствоКлюча);
			КонецЕсли; 
		Иначе	
			СвойстваИсточника = ТипXDTO.Свойства;
		КонецЕсли; 
		
		Для каждого Свойство Из СвойстваИсточника Цикл
			    			
			ИмяСвойства		= Свойство.Имя;
			ЗначениеXDTO 	= ИсточникXDTO[ИмяСвойства];
			ТипЗначения  	= ТипЗнч(Свойство.Тип);
			ЭтоСписок		= Свойство.ВерхняяГраница > 1 ИЛИ Свойство.ВерхняяГраница = -1;
			
			Если ЗначениеXDTO <> Неопределено Тогда  
			
				Если ТипЗначения = Тип("ТипЗначенияXDTO") Тогда 
					Если ЭтоСписок Тогда
						Для каждого ЭлементСпискаXDTO Из ЗначениеXDTO Цикл
							Результат[ИмяСвойства].Добавить(ЭлементСпискаXDTO);	
						КонецЦикла; 							
					Иначе
						Результат[ИмяСвойства] = ЗначениеXDTO;
					КонецЕсли;  							
				КонецЕсли;					
					
				Если ТипЗначения = Тип("ТипОбъектаXDTO") Тогда 					
					Если ЭтоСписок Тогда
						Для каждого ЭлементСпискаXDTO Из ЗначениеXDTO Цикл
							Результат[ИмяСвойства].Добавить(ЭлементСпискаXDTO);	
						КонецЦикла; 							
					Иначе
						Результат[ИмяСвойства] = СкопироватьОбъектXDTO(ЗначениеXDTO);
					КонецЕсли; 				
				КонецЕсли; 
			
			КонецЕсли;
			
		КонецЦикла; 
		
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

// Проверяет наличие свойства у объекта XDTO
//
// Параметры:
//  ДанныеXDTO			 - ОбъектXDTO	 - исходный объект XDTO
//  ИмяСвойства			 - Строка	 - имя свойства
//  СвойстваXDTO 		 - СвойствоXDTO	 - проверяемое СвойствоXDTO
// 
// Возвращаемое значение:
//   - Булево - Истина, если свойство есть
//
Функция ЕстьСвойствоXDTO(ДанныеXDTO, ИмяСвойства, СвойстваXDTO = Неопределено) Экспорт
	 	
	Если ТипЗнч(ДанныеXDTO) = Тип("ОбъектXDTO") Тогда
		КоллекцияСвойств = ДанныеXDTO.Свойства();	
	ИначеЕсли ТипЗнч(ДанныеXDTO) = Тип("ТипОбъектаXDTO") Тогда 
		КоллекцияСвойств = ДанныеXDTO.Свойства;	
	ИначеЕсли ТипЗнч(ДанныеXDTO) = Тип("КоллекцияСвойствXDTO") Тогда 
		КоллекцияСвойств = ДанныеXDTO;	
	Иначе
		Возврат Ложь;
	КонецЕсли; 
	
	СвойстваXDTO = КоллекцияСвойств.Получить(ИмяСвойства);
	
	Возврат СвойстваXDTO <> Неопределено;
	
КонецФункции

// Возвращает значение поля объекта XDTO
//
// Параметры:
//  ОбъектXDTO	 - ОбъектXDTO - исходный объект
//  ИмяПоляXDTO	 - Строка	 - полный путь до значения 
// 
// Возвращаемое значение:
//   - Произвольный - значение указанного свойства
//
Функция ЗначениеXDTO(ОбъектXDTO, ИмяПоляXDTO) Экспорт
	
	Результат = Неопределено;
	
	Если ЗначениеЗаполнено(ИмяПоляXDTO) Тогда 
		
		Если Найти(ИмяПоляXDTO, ".") > 0 Тогда  		
			
			ДанныеXDTO 	= ОбъектXDTO;
			МассивСтрок = СтрРазделить(ИмяПоляXDTO, ".");		
			
			Для Сч = 0 По МассивСтрок.ВГраница() Цикл
				
				ИмяСвойства = МассивСтрок[Сч];
				
				Если ЕстьСвойствоXDTO(ДанныеXDTO, ИмяСвойства) Тогда
					ДанныеXDTO = ДанныеXDTO[ИмяСвойства];
				Иначе
					Возврат Неопределено;	
				КонецЕсли;				
				
			КонецЦикла;			
			
			Результат = ДанныеXDTO;
			
		Иначе 		
			Результат = ДанныеXDTO[ИмяПоляXDTO];  					
		КонецЕсли;
		
	Иначе
		Результат = ОбъектXDTO;	
	КонецЕсли; 	 
	
	Возврат Результат;
	
КонецФункции   

// Возвращает количество элементов в списках контейнера
//
// Параметры:
//  КонтейнерКоллекцийXDTO	 - ОбъектXDTO	 - исходный объект XDTO
//  БезВложенныхСписков		 - Булево 	 - признак проверки вложенных списков XDTO 
// 
// Возвращаемое значение:
//   - Число - количество элементов в списках
//
Функция КоличествоВСпискахXDTO(КонтейнерКоллекцийXDTO, БезВложенныхСписков = Истина) Экспорт
	
	Результат = 0;
	
	Для каждого Ит Из КонтейнерКоллекцийXDTO.Свойства() Цикл
		
		Если ТипЗнч(КонтейнерКоллекцийXDTO[Ит.Имя]) = Тип("СписокXDTO") Тогда
			Результат = Результат + КонтейнерКоллекцийXDTO[Ит.Имя].Количество();	
		КонецЕсли; 
		
	КонецЦикла; 
	
	Возврат Результат;
	
КонецФункции

