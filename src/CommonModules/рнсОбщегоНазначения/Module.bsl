#Область Метаданные
 
// Возвращает Истина, если переданный тип является ссылочным
//
// Параметры:
//  ТипЗначения	 - Тип	 - тип значения
// 
// Возвращаемое значение:
//   - Булево - признак, что тип ссылочный
//
Функция ЭтоСсылочныйТип(ТипЗначения) Экспорт
	
	Результат = Ложь;
	
	Если ТипЗначения <> Тип("Дата") И ТипЗначения <> Тип("Строка") 
			И ТипЗначения <> Тип("Число") И ТипЗначения <> Тип("Булево") Тогда  	 
	
		ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипЗначения);
		Если ОбъектМетаданных <> Неопределено Тогда   		
			
			ИмяОбъектаМетаданных = ОбъектМетаданных.ПолноеИмя();
			Позиция = СтрНайти(ИмяОбъектаМетаданных, ".");
			Если Позиция > 0 Тогда 
				ИмяБазовогоТипа = Лев(ИмяОбъектаМетаданных, Позиция - 1);
				Результат = ИмяБазовогоТипа = "Справочник"
				Или ИмяБазовогоТипа = "Документ"
				Или ИмяБазовогоТипа = "БизнесПроцесс"
				Или ИмяБазовогоТипа = "Задача"
				Или ИмяБазовогоТипа = "ПланСчетов"
				Или ИмяБазовогоТипа = "ПланОбмена"
				Или ИмяБазовогоТипа = "ПланВидовХарактеристик"
				Или ИмяБазовогоТипа = "ПланВидовРасчета"; 			 	
				
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает текст запроса к таблице изменений объекта ИБ
//
// Параметры:
//  МассивМетаданных		 - Массив	 - массив метаданных
//  Колонки					 - Строка	 - строка с именами колонок 
//  ОграничениеПоУзлам		 - Булево	 - признак добавления условия по узлам 
//  ДляДинамическогоСписка	 - Булево	 - признак обертывания во вложенный запрос
// 
// Возвращаемое значение:
//   - Строка - текст запроса
//
Функция ТекстЗапросаКТаблицеИзмененийОбъектов(МассивМетаданных, Колонки = "", ОграничениеПоУзлам = Истина, ДляДинамическогоСписка = Ложь) Экспорт
	
	Первый			= Истина;
	Результат 		= "";		
	ТекстКолонки	= ""; 	
	
	Если ЗначениеЗаполнено(Колонки) Тогда
		
		МассивКолонок = СтрРазделить(Колонки, ",");
		
		Для каждого Ит Из МассивКолонок Цикл  			
			ТекстКолонки = "Таблица." + Ит + "," + Символы.ПС;				 					
		КонецЦикла; 
		
		ТекстКолонки = Лев(ТекстКолонки, СтрДлина(ТекстКолонки) - 2) + Символы.ПС;
		
	Иначе
		ТекстКолонки = "Таблица.Узел КАК Узел,
	              	  	|Таблица.НомерСообщения КАК НомерСообщения,
	              	  	|Таблица.Ссылка КАК Ссылка
						|";
	КонецЕсли; 	
	
	Для каждого МетаданныеОбъекта Из МассивМетаданных Цикл
		
		Если ПравоДоступа("Просмотр", МетаданныеОбъекта) Тогда
               
			Если Не Первый Тогда
				Результат = Результат + ОбщегоНазначения.ТекстОбъединитьВсе();	
			КонецЕсли; 
			
			Результат = Результат + "ВЫБРАТЬ " + ?(Первый И НЕ ДляДинамическогоСписка, "РАЗРЕШЕННЫЕ", "") + " 
			|	" + ТекстКолонки + "
			|ИЗ
			|	" + МетаданныеОбъекта.ПолноеИмя() + ".Изменения КАК Таблица";
			
			Если ОграничениеПоУзлам Тогда
				Результат = Результат + Символы.ПС + "ГДЕ Таблица.Узел В (&Узел)" + Символы.ПС;	
			КонецЕсли;  
			
			Если Первый Тогда
				Первый = Ложь;  			
			КонецЕсли; 
		
		КонецЕсли;
		
	КонецЦикла;	 
	
	Если ДляДинамическогоСписка Тогда
		Результат = "ВЫБРАТЬ РАЗРЕШЕННЫЕ * ИЗ (" + Результат + ") КАК Данные ";		
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции
      
// Получает метаданные объекта по форме
//
// Параметры:
//  Форма	 - Форма, Строка	 - форма или имя формы
// 
// Возвращаемое значение:
//   -  ОбъектМетаданных - объект метаданных, владелец формы
//
Функция МетаданныеОбъектаПоФорме(Форма) Экспорт
	
	Если ТипЗнч(Форма) = Тип("Строка") Тогда
		ПолноеИмяФормы = Форма;
	Иначе
		ПолноеИмяФормы = Форма.ИмяФормы;	
	КонецЕсли;   
	
	Результат 			= Неопределено;
	МетаданныеФормы 	= Метаданные.НайтиПоПолномуИмени(ПолноеИмяФормы);
	
	Если МетаданныеФормы <> Неопределено Тогда  
		
		РодительМетаданные = МетаданныеФормы.Родитель();
		
		Если ТипЗнч(РодительМетаданные) <> Тип("ОбъектМетаданныхКонфигурация") Тогда  		
			Результат = РодительМетаданные;		
		КонецЕсли;	
		
	КонецЕсли; 	
	
	Возврат Результат;		

КонецФункции 

// Возвращает приведенное значение типа
//
// Параметры:
//  ТипЗначения	 - Тип, ОписаниеТипов	 - тип значения
//  Значение	 - Произвольный		 - приводимое к Типу значение
// 
// Возвращаемое значение:
//   - Произвольный - значение заданного типа
//
Функция ПривестиЗначениеКТипу(ТипЗначения, Значение = Неопределено) Экспорт
	
	Если ТипЗнч(ТипЗначения) = Тип("ОписаниеТипов") Тогда  
		ОписаниеТипов = ТипЗначения;
	Иначе
		
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(ТипЗначения);
		
		ОписаниеТипов = Новый ОписаниеТипов(МассивТипов);
		
	КонецЕсли; 		
	
	Возврат ОписаниеТипов.ПривестиЗначение(Значение);
	
КонецФункции 

// Создает таблицу значений согласно переданной коллекции реквизитов
//
// Параметры:
//  МетаданныеРеквзиитов - КоллекцияОбъектовМетаданных	 - коллекция метаданных реквизитов
//  Колонки				 - Строка, Массив	 - список колонок
// 
// Возвращаемое значение:
//   - ТаблицаЗначений - таблица с указанным списком колонок
//
Функция ИнициализироватьТаблицуПоМетаданным(МетаданныеРеквзиитов, Колонки = Неопределено) Экспорт
	                                    	
	Результат = Новый ТаблицаЗначений;	
	
	Если ТипЗнч(Колонки) = Тип("Строка") Тогда 
		СписокКолонок = СтрРазделить(Колонки, ",", Ложь);	
	ИначеЕсли ТипЗнч(Колонки) = Тип("Массив") Тогда   
		СписокКолонок = Колонки; 
	Иначе     
		СписокКолонок = Неопределено;  
	КонецЕсли; 	
	
	Если ЗначениеЗаполнено(СписокКолонок) Тогда    	
		Для каждого Реквизит Из МетаданныеРеквзиитов Цикл 
			Если СписокКолонок.Найти(Реквизит.Имя) <> Неопределено Тогда 
				Результат.Колонки.Добавить(Реквизит.Имя, Реквизит.Тип);
			КонецЕсли; 
		КонецЦикла;
	Иначе
		Для каждого Реквизит Из МетаданныеРеквзиитов Цикл 
			Результат.Колонки.Добавить(Реквизит.Имя, Реквизит.Тип);
		КонецЦикла;  
	КонецЕсли; 
	
	Возврат Результат; 	
	
КонецФункции  

#КонецОбласти 

#Область ТабличныйДокумент

// Возвращает значение из ячейки табличного документа
//
// Параметры:
//  ОбластьДокумента - ТабличныйДокумент	 - исходный документ
//  НомерСтроки		 - Число	 - номер строки 
//  НомерКолонки	 - Число	 - номер колонки
// 
// Возвращаемое значение:
//   - Произвольный - значение из ячейки
//
Функция ЗначениеЯчейкиТД(ОбластьДокумента, НомерСтроки, НомерКолонки) Экспорт
	
	Результат 			= Неопределено; 	
	Область 			= ОбластьДокумента.ПолучитьОбласть("R" + Формат(НомерСтроки, "ЧГ=0") + "C" + Формат(НомерКолонки, "ЧГ=0"));   	
	ТекущаяОбласть 		= Область.ТекущаяОбласть;
	
	Если ТекущаяОбласть.СодержитЗначение Тогда
		Результат = ТекущаяОбласть.Значение;
	Иначе
		
		Результат = СокрЛП(ТекущаяОбласть.Текст);   
		
		Если ЗначениеЗаполнено(Результат) Тогда
			Результат = ПривестиСтрокуКПростомуТипу(Результат); 			
		Иначе
			Результат = Неопределено; // здесь можно анализировать наличие картинки	
		КонецЕсли;	
		
	КонецЕсли; 	
	
	Возврат Результат;
	
КонецФункции

// Возвращает текст из всех ячеек указанной области
//
// Параметры:
//  Макет		 - ТабличныйДокумент	 - исходный документ
//  ИмяОбласти	 - Строка	 - имя области
// 
// Возвращаемое значение:
//   - Строка - текст из всех областей
//
Функция ТекстОбласти(Макет, ИмяОбласти = "") Экспорт
		
	Результат = "";
	
	Если ЗначениеЗаполнено(ИмяОбласти) Тогда
		ОбластьТабличногоДокумента = Макет.ПолучитьОбласть(ИмяОбласти);	
	Иначе
		ОбластьТабличногоДокумента = Макет;		
	КонецЕсли; 		
		
	Если ОбластьТабличногоДокумента <> Неопределено Тогда 		
		
		Области = ОбластьТабличногоДокумента.Области; 		
		
		Если Области.Количество() > 1 Тогда
			Для каждого Ит Из Области Цикл
				Если Ит.Имя <> ИмяОбласти Тогда
					Результат = Результат + Ит.Текст + Символы.ПС;	
				КонецЕсли; 					
			КонецЦикла;
		Иначе
			Результат = ОбластьТабличногоДокумента.ТекущаяОбласть.Текст;	
		КонецЕсли; 
		
	КонецЕсли; 	
	
	Возврат СокрЛП(Результат);
	
КонецФункции  

// Расширяет область табличного документа
//
// Параметры:
//  ОбластьМакета	 - ТабличныйДокумент	 - исходный документ
//  КоличествоЯчеек	 - Число	 - размер расширения
//  Линия			 - Линия	 - обводит область рамкой указанной линией
//
Процедура РасширитьОбласть(ОбластьМакета, КоличествоЯчеек, Линия = Неопределено) Экспорт
	
	Если КоличествоЯчеек > 1 Тогда 	 
	
		Область = ОбластьМакета.ТекущаяОбласть;		
		
		НоваяОбласть = ОбластьМакета.Область(Область.Верх, Область.Лево, Область.Низ + КоличествоЯчеек - 1, Область.Право + ОбластьМакета.ШиринаТаблицы - 1);
		НоваяОбласть.Объединить();
		
		Если Линия <> Неопределено Тогда 		 
			НоваяОбласть.Обвести(Линия, Линия, Линия, Линия);	
		КонецЕсли; 
	
	КонецЕсли;
	
КонецПроцедуры 

// Преобразует табличный документ в документ HTML с картинками 
//
// Параметры:
//  ТабДок	 - ТабличныйДокумент	 - исходный документ
// 
// Возвращаемое значение:
//   - ДокументHTML - полученный документ
//
Функция ТабличныйДокументВДокументHTML(ТабДок) Экспорт
	
	ЧтениеHTML 		= Новый ЧтениеHTML;
	ПостроительDOM 	= Новый ПостроительDOM;
	
	// Через поток??? Поток = Новый ПотокВПамяти(); ТабДок.Записать(Поток, ТипФайлаТабличногоДокумента.HTML5);ЧтениеHTML.ОткрытьПоток(Поток);Возврат ПостроительDOM.Прочитать(ЧтениеHTML);
	
	ФайлВФорматеHTML = ПолучитьИмяВременногоФайла(); 
	
	ТабДок.Записать(ФайлВФорматеHTML, ТипФайлаТабличногоДокумента.HTML5);
	
	ЧтениеHTML = Новый ЧтениеHTML;
	ЧтениеHTML.ОткрытьФайл(ФайлВФорматеHTML);
	ПостроительDOM = Новый ПостроительDOM;
	
	Результат = ПостроительDOM.Прочитать(ЧтениеHTML);
	
	ЧтениеHTML.Закрыть();
	УдалитьФайлы(ФайлВФорматеHTML); 
	
	Возврат Результат;
   
КонецФункции

// Преобразует табличный документ в текст HTML
//
// Параметры:
//  ТабДок	 - ТабличныйДокумент	 - исходный документ
//  Вложения - Массив	 - массив  вложения HTML документа 
// 
// Возвращаемое значение:
//   - Строка - текст html
//
Функция ТабличныйДокументВТекстHTML(ТабДок, Вложения = Неопределено) Экспорт
	                                   
	НПП 				= 0;	
	ДокументHTML 		= ТабличныйДокументВДокументHTML(ТабДок);	 	
	
	Для Каждого Картинка Из ДокументHTML.Картинки Цикл
		
		ИмяКартинки = "image" + Формат(НПП, "ЧЦ=3; ЧВН=");
		
		АтрибутИсточникКартинки = Картинка.Атрибуты.ПолучитьИменованныйЭлемент("src");
		АтрибутИсточникКартинки.ТекстовоеСодержимое = "cid:" + ИмяКартинки; 
		
		ДвоичныеДанныеКартинки = ПоместитьВоВременноеХранилище(ТабДок.Области.Шапка.Картинка.ПолучитьДвоичныеДанные());
		
		Вложение = Новый Структура("Представление, АдресВоВременномХранилище, Идентификатор", ИмяКартинки, ДвоичныеДанныеКартинки, ИмяКартинки);
	                                        
		Вложения.Добавить(Вложение);
		
		НПП = НПП + 1;
		
	КонецЦикла; 	 	
	
	Возврат ИсходныйТекстДокументаHTML(ДокументHTML);
	
КонецФункции 

#КонецОбласти 

#Область ДокументHTML

// Возвращает текст документа HTML
//
// Параметры:
//  ДокументHTML - ДокументHTML	 - документ HTML
// 
// Возвращаемое значение:
//   - Строка - текст html
//
Функция ИсходныйТекстДокументаHTML(ДокументHTML) Экспорт
   ЗаписьDOM = Новый ЗаписьDOM; 
   ЗаписьHTML = Новый ЗаписьHTML;
   ЗаписьHTML.УстановитьСтроку(); 
   ЗаписьDOM.Записать(ДокументHTML, ЗаписьHTML);
   Возврат ЗаписьHTML.Закрыть();
КонецФункции  

