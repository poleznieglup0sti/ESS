#Область СлужебныеПроцедурыИФункции   
     
Процедура КопироватьСтроки(КоллекцияСтрокИсточника, КоллекцияСтрокПриемника)

	Для Каждого ТекущаяСтрокаИсточника Из КоллекцияСтрокИсточника Цикл

		НоваяСтрокаПриемника = КоллекцияСтрокПриемника.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаПриемника, ТекущаяСтрокаИсточника);

		Если ЗначениеЗаполнено(ТекущаяСтрокаИсточника.Строки) Тогда
			КопироватьСтроки(ТекущаяСтрокаИсточника.Строки, НоваяСтрокаПриемника.Строки);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры
         
Процедура ДобавитьЭлементыОтображенияСтрокиТаблицы(Форма, ИмяТаблицыОтображения, Родитель, СвойстваКлюча, СвойстваСписка, КлючСписка = Неопределено, Список = Неопределено) 
	
	ДействияСписка		= Неопределено;
	ДействияКлюча 		= Неопределено;
	ЭлементыФормы 		= Форма.Элементы;                                                                              		
	КоличествоСтрок		= Форма[ИмяТаблицыОтображения].Количество();
	СвойстваКлюча       = Новый Структура;
	СвойстваСписка      = Новый Структура;
	СвойстваГруппы 		= Новый Структура("Вид, Группировка", ВидГруппыФормы.ОбычнаяГруппа, ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
	Идентификатор 		= СтрЗаменить(Новый УникальныйИдентификатор, "-", ""); 
	
	СвойстваКлюча.Вставить("Заголовок", СвойстваКлюча.ЗаголовокКлюча);
	СвойстваКлюча.Вставить("Вид", ВидПоляФормы.ПолеВвода);
	СвойстваКлюча.Вставить("ПутьКДанным",  ИмяТаблицыОтображения + "[" + КоличествоСтрок + "].КлючСписка");
	СвойстваКлюча.Вставить("КнопкаОчистки", Истина);  
	
	СвойстваСписка.Вставить("Заголовок", СвойстваСписка.ЗаголовокСписка);
	СвойстваСписка.Вставить("Вид", ВидПоляФормы.ПолеВвода);
	СвойстваСписка.Вставить("ПутьКДанным", ИмяТаблицыОтображения + "[" + КоличествоСтрок + "].СписокЗначений");
	СвойстваСписка.Вставить("КнопкаОчистки", Истина);	
	        	
	Если СвойстваКлюча.Свойство("ДействияКлюча", ДействияКлюча) Тогда
		СвойстваКлюча.Вставить("Действия", ДействияКлюча);		
	КонецЕсли; 
	
	Если СвойстваСписка.Свойство("ДействияСписка", ДействияСписка) Тогда
		СвойстваСписка.Вставить("Действия", ДействияСписка);		
	КонецЕсли;	 
	
	НоваяСтрока 					= Форма[ИмяТаблицыОтображения].Добавить();		
	НоваяСтрока.ИдентификаторКлюча 	= Идентификатор;
	НоваяСтрока.КлючСписка 			= КлючСписка;
	НоваяСтрока.СписокЗначений 		= ?(Список = Неопределено, Новый СписокЗначений, Список);
	
	ГруппаЭлементаНабора = СоздатьЭлементФормы(ЭлементыФормы, "Группа_" + Идентификатор, СвойстваГруппы, Тип("ГруппаФормы"), Родитель, Неопределено);
	
	СоздатьЭлементФормы(ЭлементыФормы, "ПолеКлюча_" + Идентификатор, СвойстваКлюча, Тип("ПолеФормы"), ГруппаЭлементаНабора, Неопределено);
	СоздатьЭлементФормы(ЭлементыФормы, "ПолеСписка_" + Идентификатор, СвойстваСписка, Тип("ПолеФормы"), ГруппаЭлементаНабора, Неопределено);
	
КонецПроцедуры

Процедура ЗаполнитьТаблицуСоСписком(Таблица, ИмяКолонки, ИсточникДанных)
	
	Для каждого Ит Из ИсточникДанных Цикл
		Если ТипЗнч(Ит.Значение) = Тип("Соответствие") Тогда
			ЗаполнитьТаблицуСоСписком(Таблица, ИмяКолонки, Ит.Значение);
		ИначеЕсли ТипЗнч(Ит.Значение) = Тип("Массив") Тогда 
			
			НоваяСтрока = Таблица.Добавить();
			
			Для каждого Элемент Из Ит.Значение Цикл  				
				НоваяСтрока[ИмяКолонки].Добавить(Элемент[ИмяКолонки]);
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент, , ИмяКолонки);	
			КонецЦикла;  
			
		Иначе       			
			НоваяСтрока = Таблица.Добавить();
			НоваяСтрока[ИмяКолонки].Добавить(ИсточникДанных[ИмяКолонки]);
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсточникДанных, , ИмяКолонки);   		
		КонецЕсли; 	
	КонецЦикла; 
	
КонецПроцедуры

Функция ПривестиСтрокуКПростомуТипу(Знач ЗначениеЯчейки)
	
	Результат = ЗначениеЯчейки; 	
	
	Попытка
		Результат = Число(ЗначениеЯчейки);
	Исключение
		
		Если ВРег(ЗначениеЯчейки) = "ИСТИНА" ИЛИ ВРег(ЗначениеЯчейки) = "TRUE" Тогда
			Результат = Истина;
		ИначеЕсли ВРег(ЗначениеЯчейки) = "ЛОЖЬ" ИЛИ ВРег(ЗначениеЯчейки) = "FALSE" Тогда
			Результат = Ложь;
		Иначе
			Попытка
				Результат = Дата(ЗначениеЯчейки);	
			Исключение   
				Результат = Неопределено;	
			КонецПопытки; 			
		КонецЕсли;	
		
	КонецПопытки; 	
	
	Возврат Результат;
	
КонецФункции

#Область СлужебныеПроцедурыФункцииЕстьИзмененияОбъектаСсылочногоТипа

Функция КоллекцияШаблоновЗапросовКонтрольИзмененияОбъектаСсылочногоТипа()
		  		   
	Результат = Новый Структура;  		
	
	ШаблонСравненияТабличнойЧастиПоПоказателям = "ВЫБРАТЬ 
												|""#ИмяТабличнойЧасти#"" КАК ИмяТабличнойЧасти, 
												|#ИтоговыеПоказатели#
												|#ИтоговыеКолонки#												
												|ИЗ (ВЫБРАТЬ
												|#ПоказателиПосле#
												|#Колонки#												
												|ИЗ
												|	#ТабличнаяЧасть# КАК Таблица
												|
												|ОБЪЕДИНИТЬ ВСЕ 
												|
												|ВЫБРАТЬ 
												|#ПоказателиДо#
												|#Колонки#												 								 
												|ИЗ #Таблица#.#ИмяТабличнойЧасти# КАК Таблица
												|ГДЕ 
												|	Таблица.Ссылка = &Ссылка) КАК ДанныеСравнения
												|СГРУППИРОВАТЬ ПО
												|#КолонкиГруппировки#
												|ИМЕЮЩИЕ 
												|	#УсловияПоПоказателям#
												|";   	
	
	ШаблонСравненияТабличнойЧасти = "ВЫБРАТЬ 
									|""#ИмяТабличнойЧасти#"" КАК ИмяТабличнойЧасти, 
									|#ИтоговыеКолонки#, 
									|СУММА(ДанныеСравнения._СГПоле) 
									|ИЗ (ВЫБРАТЬ 				              
									|#Колонки#,
									|1 КАК _СГПоле
									|ИЗ
									|	#ТабличнаяЧасть# КАК Таблица
									|
									|ОБЪЕДИНИТЬ ВСЕ 
									|
									|ВЫБРАТЬ 
									|#Колонки#,
									|-1 КАК _СГПоле 								 
									|ИЗ #Таблица#.#ИмяТабличнойЧасти# КАК Таблица
									|ГДЕ 
									|	Таблица.Ссылка = &Ссылка) КАК ДанныеСравнения
									|СГРУППИРОВАТЬ ПО
									|#КолонкиГруппировки#
									|ИМЕЮЩИЕ 
									|	СУММА(ДанныеСравнения._СГПоле) <> 0
									|
									|ИТОГИ ПО  									
	       							|	ДанныеСравнения.НомерСтроки";
	
	ШаблонВтТабличнойЧастиПередЗаписью = "ВЫБРАТЬ				              
							  			|#Колонки#
							  			|ПОМЕСТИТЬ Вт_#ИмяТабличнойЧасти#
							  			|ИЗ
							  			|	&#ИмяТабличнойЧасти# КАК Таблица";								  
							  
	ШаблонЗапросаКонтроляРеквизитовШапки = "ВЫБРАТЬ 
									|	#Колонки# 	
									|
									|ИЗ #Таблица# КАК Таблица
									|ГДЕ 
							  		|	Таблица.Ссылка = &Ссылка";  	 	
	
	ШаблонПоляТаблицы						= "Таблица.#ИмяРеквизита#"; 
	ШаблонВыборкиПоляТаблицы				= "#Колонка# КАК #ИмяРеквизита#";
	ШаблонУсловияПоказателя					= "СУММА(ДанныеСравнения.#ИмяРеквизита#) <> 0"; 	
	ШаблонВыбораИтоговогоПоказателя			= "СУММА(ДанныеСравнения.#ИмяРеквизита#) КАК #ИмяРеквизита#";
	ШаблонВыборкиПоказателя					= "#Знак#Таблица.#ИмяРеквизита# КАК #ИмяРеквизита#";
	ШаблонУничтоженияВТ						= "УНИЧТОЖИТЬ Вт_#ИмяТабличнойЧасти#" + ОбщегоНазначения.РазделительПакетаЗапросов();
	ШаблонСтроковогоПоляНеограниченнойДлины = "ВЫРАЗИТЬ(Таблица.#ИмяРеквизита# КАК СТРОКА(1024))";
	
	Результат.Вставить("ШаблонСравненияТабличнойЧастиПоПоказателям", 	ШаблонСравненияТабличнойЧастиПоПоказателям);
	Результат.Вставить("ШаблонУсловияПоказателя", 						ШаблонУсловияПоказателя); 
	Результат.Вставить("ШаблонВыбораИтоговогоПоказателя", 				ШаблонВыбораИтоговогоПоказателя);
	Результат.Вставить("ШаблонВыборкиПоказателя", 						ШаблонВыборкиПоказателя);	
	Результат.Вставить("ШаблонСравненияТабличнойЧасти", 				ШаблонСравненияТабличнойЧасти);  	
	Результат.Вставить("ШаблонВтТабличнойЧастиПередЗаписью", 			ШаблонВтТабличнойЧастиПередЗаписью);	
	Результат.Вставить("ШаблонЗапросаКонтроляРеквизитовШапки", 			ШаблонЗапросаКонтроляРеквизитовШапки);
	Результат.Вставить("ШаблонУничтоженияВТ", 							ШаблонУничтоженияВТ); 
	Результат.Вставить("ШаблонВыборкиПоляТаблицы", 						ШаблонВыборкиПоляТаблицы);	
	Результат.Вставить("ШаблонПоляТаблицы", 							ШаблонПоляТаблицы);  
	Результат.Вставить("ШаблонСтроковогоПоляНеограниченнойДлины", 		ШаблонСтроковогоПоляНеограниченнойДлины);
	
	
	Возврат Результат;
	
КонецФункции
 
Функция ТекстЗапросаСравненияОбъектаСсылочногоТипа(ИмяТаблицы, ОписаниеКолонокШапки, ОписаниеКолонокТабличныхЧастей)
	
	Результат 								= "";
	ТекстЗапросаКолонкиШапки 				= ""; 
	ТекстЗапросаКШапкеОбъекта				= "";
	ТекстЗапросВтКТабличнымЧастям 			= "";
	ТекстЗапросаСравненияТабличныхЧастей	= ""; 
	ТекстЗапросаУничтожениеВТ 				= "";
	РазделительКолонок						= "," + Символы.ПС;
	РазделительУсловий						= " ИЛИ " + Символы.ПС;
	КоллекцияШаблонов 						= КоллекцияШаблоновЗапросовКонтрольИзмененияОбъектаСсылочногоТипа();
	
	Если ЗначениеЗаполнено(ОписаниеКолонокШапки) Тогда 		  
		
		ШаблонЗаполнения = КоллекцияШаблонов.ШаблонПоляТаблицы;
		
		Для каждого Ит Из ОписаниеКолонокШапки Цикл			  		
			ТекстЗапросаКолонкиШапки = ТекстЗапросаКолонкиШапки + СтрЗаменить(ШаблонЗаполнения, "#ИмяРеквизита#", Ит.ИмяРеквизита) + РазделительКолонок; 			
		КонецЦикла; 
		
		ТекстЗапросаКолонкиШапки = Лев(ТекстЗапросаКолонкиШапки, СтрДлина(ТекстЗапросаКолонкиШапки) - СтрДлина(РазделительКолонок));		
		ТекстЗапросаКШапкеОбъекта = СтрЗаменить(КоллекцияШаблонов.ШаблонЗапросаКонтроляРеквизитовШапки, "#Таблица#", ИмяТаблицы);
		ТекстЗапросаКШапкеОбъекта = СтрЗаменить(ТекстЗапросаКШапкеОбъекта, "#Колонки#", ТекстЗапросаКолонкиШапки);    	
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеКолонокТабличныхЧастей) Тогда		
		
		Для каждого Ит Из ОписаниеКолонокТабличныхЧастей Цикл
			
			ТекстЗапросаСравнениеТабличнойЧасти		= "";
			ТекстЗапросаВыборкаПоказателейВнутриВЗ	= "";
			ТекстЗапросаУсловияПоПоказателям		= "";
			ТекстЗапросаИтоговыеПоказатели			= "";
			ТекстЗапросаВыборкаПоказателей			= "";
			ТекстВыборкиПоля						= "";
			ТекстПоляГруппировки               	 	= "";
			ТекстЗапросаВыборкаПолей				= "";  		
			
			ИмяТабличнойЧасти 						= Ит.Ключ;
			КолонкиТабличнойЧасти 					= Ит.Значение.Колонки;
			ПоказателиТабличнойЧасти 				= Ит.Значение.Показатели; 
			ИмяТаблицыВТ							= Ит.Значение.ИмяТаблицыВТ;    
			НеЗагружатьТабличнуюЧасть				= ЗначениеЗаполнено(ИмяТаблицыВТ);
			
			Для каждого ОписаниеКолонки Из КолонкиТабличнойЧасти Цикл
				
				Если ОписаниеКолонки.ЭтоСтрокаНеограниченноДлины Тогда
					ШаблонЗаполнения = КоллекцияШаблонов.ШаблонСтроковогоПоляНеограниченнойДлины;	
				Иначе
					ШаблонЗаполнения = КоллекцияШаблонов.ШаблонПоляТаблицы;	
				КонецЕсли;  				
				
				ТекстВыборкиПоля 			= СтрЗаменить(КоллекцияШаблонов.ШаблонВыборкиПоляТаблицы, "#Колонка#", ШаблонЗаполнения);
				ТекстЗапросаВыборкаПолей 	= ТекстЗапросаВыборкаПолей + СтрЗаменить(ТекстВыборкиПоля, "#ИмяРеквизита#", ОписаниеКолонки.ИмяРеквизита) + РазделительКолонок;
				ТекстПоляГруппировки		= ТекстПоляГруппировки + СтрЗаменить(КоллекцияШаблонов.ШаблонПоляТаблицы, "#ИмяРеквизита#", ОписаниеКолонки.ИмяРеквизита) + РазделительКолонок;
				
			КонецЦикла; 
			
			ТекстЗапросаВыборкаПолей = Лев(ТекстЗапросаВыборкаПолей, СтрДлина(ТекстЗапросаВыборкаПолей) - СтрДлина(РазделительКолонок));
			ТекстПоляГруппировки = Лев(ТекстПоляГруппировки, СтрДлина(ТекстПоляГруппировки) - СтрДлина(РазделительКолонок));
			
			Если ЗначениеЗаполнено(ПоказателиТабличнойЧасти) Тогда
				
				Для каждого Показатель Из ПоказателиТабличнойЧасти Цикл    					
					ТекстЗапросаВыборкаПоказателей 			= ТекстЗапросаВыборкаПоказателей + СтрЗаменить(КоллекцияШаблонов.ШаблонПоляТаблицы, "#ИмяРеквизита#", Показатель) + РазделительКолонок;
					ТекстЗапросаВыборкаПоказателейВнутриВЗ 	= ТекстЗапросаВыборкаПоказателейВнутриВЗ + СтрЗаменить(КоллекцияШаблонов.ШаблонВыборкиПоказателя, "#ИмяРеквизита#", Показатель) + РазделительКолонок;
					ТекстЗапросаИтоговыеПоказатели			= ТекстЗапросаИтоговыеПоказатели + СтрЗаменить(КоллекцияШаблонов.ШаблонВыбораИтоговогоПоказателя, "#ИмяРеквизита#", Показатель) + РазделительКолонок;
					ТекстЗапросаУсловияПоПоказателям		= ТекстЗапросаУсловияПоПоказателям +  СтрЗаменить(КоллекцияШаблонов.ШаблонУсловияПоказателя, "#ИмяРеквизита#", Показатель) + РазделительУсловий;  					
				КонецЦикла; 			
				
				ТекстЗапросаУсловияПоПоказателям = Лев(ТекстЗапросаУсловияПоПоказателям, СтрДлина(ТекстЗапросаУсловияПоПоказателям) - СтрДлина(РазделительУсловий));
				                      				
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(КоллекцияШаблонов.ШаблонСравненияТабличнойЧастиПоПоказателям, "#Таблица#", ИмяТаблицы);  			
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#Колонки#", ТекстЗапросаВыборкаПолей);
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#КолонкиГруппировки#", СтрЗаменить(ТекстПоляГруппировки, "Таблица.", "ДанныеСравнения.")); 				
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#ИтоговыеКолонки#", СтрЗаменить(ТекстЗапросаВыборкаПолей, "Таблица.", "ДанныеСравнения."));
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#ИтоговыеПоказатели#", ТекстЗапросаИтоговыеПоказатели);
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#ПоказателиПосле#", СтрЗаменить(ТекстЗапросаВыборкаПоказателейВнутриВЗ, "#Знак#", "-"));	
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#ПоказателиДо#", СтрЗаменить(ТекстЗапросаВыборкаПоказателейВнутриВЗ, "#Знак#", ""));
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#УсловияПоПоказателям#", ТекстЗапросаУсловияПоПоказателям);	
				            				
			Иначе				
				
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(КоллекцияШаблонов.ШаблонСравненияТабличнойЧасти, "#Таблица#", ИмяТаблицы);  			
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#Колонки#", ТекстЗапросаВыборкаПолей);
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#КолонкиГруппировки#", СтрЗаменить(ТекстПоляГруппировки, "Таблица.", "ДанныеСравнения."));
				ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#ИтоговыеКолонки#", СтрЗаменить(ТекстЗапросаВыборкаПолей, "Таблица.", "ДанныеСравнения."));
			          			
			КонецЕсли; 
			
			ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#ТабличнаяЧасть#", ?(НеЗагружатьТабличнуюЧасть, ИмяТаблицыВТ, "Вт_" + ИмяТабличнойЧасти));
			ТекстЗапросаСравнениеТабличнойЧасти = СтрЗаменить(ТекстЗапросаСравнениеТабличнойЧасти, "#ИмяТабличнойЧасти#", ИмяТабличнойЧасти);
			
			Если НЕ НеЗагружатьТабличнуюЧасть Тогда   			
				
				ТекстЗапросКТабличнойЧасти = СтрЗаменить(КоллекцияШаблонов.ШаблонВтТабличнойЧастиПередЗаписью, "#Таблица#", ИмяТаблицы);
				ТекстЗапросКТабличнойЧасти = СтрЗаменить(ТекстЗапросКТабличнойЧасти, "#ИмяТабличнойЧасти#", ИмяТабличнойЧасти);  			 
				ТекстЗапросКТабличнойЧасти = СтрЗаменить(ТекстЗапросКТабличнойЧасти, "#Колонки#", ТекстЗапросаВыборкаПоказателей + ТекстЗапросаВыборкаПолей); 
				ТекстЗапросКТабличнойЧасти = ТекстЗапросКТабличнойЧасти + ОбщегоНазначения.РазделительПакетаЗапросов();				
				
				ТекстЗапросаУничтожениеВТ = ТекстЗапросаУничтожениеВТ + СтрЗаменить(КоллекцияШаблонов.ШаблонУничтоженияВТ, "#ИмяТабличнойЧасти#", ИмяТабличнойЧасти);
				
			КонецЕсли; 		  			
			
			ТекстЗапросВтКТабличнымЧастям = ТекстЗапросВтКТабличнымЧастям + ТекстЗапросКТабличнойЧасти;
			ТекстЗапросаСравненияТабличныхЧастей = ТекстЗапросаСравненияТабличныхЧастей + ТекстЗапросаСравнениеТабличнойЧасти + ОбщегоНазначения.РазделительПакетаЗапросов();
			
		КонецЦикла; 
		
	КонецЕсли; 
	
	Результат = ТекстЗапросВтКТабличнымЧастям + ТекстЗапросаСравненияТабличныхЧастей + ТекстЗапросаУничтожениеВТ + ТекстЗапросаКШапкеОбъекта;
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьТаблицуОписанияКолонок()
	
	ТипСтрока = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(512));
	ТипБулево = Новый ОписаниеТипов("Булево");
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ИмяРеквизита", ТипСтрока);
	Результат.Колонки.Добавить("ЭтоСтрокаНеограниченноДлины", ТипБулево);  
	Результат.Колонки.Добавить("ЭтоСоставнойТип", ТипБулево);
	Результат.Колонки.Добавить("ИмяТабличнойЧасти", ТипСтрока);
		
	Возврат Результат;
	
КонецФункции     

Функция ПодготовитьТаблицуИзменений()
	
	ТипСтрока = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(512));
	ТипБулево = Новый ОписаниеТипов("Булево");
	
	Результат = Новый ТаблицаЗначений;  
	Результат.Колонки.Добавить("ИмяРеквизита", ТипСтрока);
	Результат.Колонки.Добавить("ИмяТаблицы", ТипСтрока); 
	Результат.Колонки.Добавить("НомерСтроки", ОбщегоНазначения.ОписаниеТипаЧисло(15));
	Результат.Колонки.Добавить("ЗначениеБД");
	Результат.Колонки.Добавить("ЗначениеТекущее");  
	Результат.Колонки.Добавить("ДобавленаУдалена", ТипБулево);	
	
	Возврат Результат;
	
КонецФункции

Функция ДобавитьОписаниеКолонки(ТаблицаОписания, МетаданныеРеквизита)
	
	ТипРеквизита = МетаданныеРеквизита.Тип;
	
	Результат 								= ТаблицаОписания.Добавить();
	Результат.ИмяРеквизита 					= МетаданныеРеквизита.Имя;
	Результат.ЭтоСтрокаНеограниченноДлины 	= ТипРеквизита.СодержитТип(Тип("Строка")) И ТипРеквизита.КвалификаторыСтроки.Длина = 0; 
	Результат.ЭтоСоставнойТип				= ТипРеквизита.Типы().Количество() > 1;	 
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьИзмнениеВТаблицу(ТаблицаИзмнений, ЗначениеБД, ЗначениеТекущее, ИмяРеквизита, ИмяТаблицы = "", НомерСтроки = Неопределено)
	
	НоваяСтрока 			= ТаблицаИзмнений.Добавить(); 
	НоваяСтрока.ИмяТаблицы 	= ИмяТаблицы;
	НоваяСтрока.НомерСтроки = НомерСтроки;	
	
	Если ЗначениеБД = ЗначениеТекущее Тогда
		НоваяСтрока.ДобавленаУдалена = ИмяРеквизита;	
	Иначе  	
		НоваяСтрока.ЗначениеБД 		= ЗначениеБД;
		НоваяСтрока.ЗначениеТекущее = ЗначениеТекущее;
		НоваяСтрока.ИмяРеквизита 	= ИмяРеквизита;	
	КонецЕсли;	
	
КонецПроцедуры  

Процедура ДобавитьИзменениеВСтроку(ТекстИзменений, ЗначениеБД, ЗначениеТекущее, ИмяРеквизита, ИмяТаблицы = "", НомерСтроки = Неопределено)
	                     		
	Если ЗначениеБД = ЗначениеТекущее Тогда 
		
		Если ИмяРеквизита = 1 Тогда
			ХарактерИзменения = НСтр("ru = 'Добавлена'");	
		Иначе
			ХарактерИзменения = НСтр("ru = 'Удалена'");		
		КонецЕсли;	
		
		Шаблон 			= НСтр("ru = 'Изменена табличная часть ""%1"". %2 строка табличной части №%3.'") + Символы.ПС;	
		ТекстИзменений 	= ТекстИзменений + СтрШаблон(Шаблон, ИмяТаблицы, ХарактерИзменения, НомерСтроки); 
		
	Иначе  
		
		Если ЗначениеЗаполнено(ЗначениеТекущее) Тогда 
			НовоеЗначение = ЗначениеТекущее;	
		Иначе
			НовоеЗначение = НСтр("ru = '<пустое значение>'");	
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(ЗначениеБД) Тогда	
			СтароеЗначение = ЗначениеБД;
		Иначе 		
			СтароеЗначение = НСтр("ru = '<пустое значение>'");	
		КонецЕсли; 			
		
		Если ЗначениеЗаполнено(ИмяТаблицы) Тогда 
			Шаблон			= НСтр("ru = 'Изменена табличная часть ""%1"". В строке №%2 старое значение колонки %3 - %4, установленное значение %5.'") + Символы.ПС;		   	
			ТекстИзменений 	= ТекстИзменений + СтрШаблон(Шаблон, ИмяТаблицы, НомерСтроки, ИмяРеквизита, СтароеЗначение, НовоеЗначение);
		Иначе 
			Шаблон 			= НСтр("ru = 'Изменен реквизит %1. Старое значение %2, установленное значение %3.'") + Символы.ПС;	
			ТекстИзменений 	= ТекстИзменений + СтрШаблон(Шаблон, ИмяРеквизита, СтароеЗначение, НовоеЗначение);	
		КонецЕсли; 
		
	КонецЕсли;
	
КонецПроцедуры 

