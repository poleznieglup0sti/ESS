#Область ОбработчикиСобытийФормы
                 
&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	ИспользоватьЗаполнениеХранилища = ЗначениеЗаполнено(Объект.ИмяФормыЗаполненияХранилища);
	
КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьТекстОписанияКлюча(); 
	ОбновитьНастройкуСекцийРаздела();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ФормаЗаполненияХранилищаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОтборРодителей = Новый Массив;
	ОтборРодителей.Добавить("ОбщиеФормы");	 
	ОтборРодителей.Добавить("Справочник.рнсРазделыОбщихНастроек"); 	
	ОтборРодителей.Добавить("РегистрСведений.рнсОбщиеНастройки");
	
	Оповещение 	= Новый ОписаниеОповещения("ВыборФормы_Завершение", ЭтотОбъект);  		 	
	Ограничения = Новый Структура("ПоКоллекцииМетаданных", ОтборРодителей);	  
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТипДанныхВыбора", 3);	
	ПараметрыФормы.Вставить("Ограничения", Ограничения);
	ПараметрыФормы.Вставить("МножественныйВыбор", Ложь);  
	
	Если ЗначениеЗаполнено(Объект.ИмяФормыЗаполненияХранилища) Тогда
		ПараметрыФормы.Вставить("Отмеченные", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Объект.ИмяФормыЗаполненияХранилища));	
	КонецЕсли;  
	
	ОткрытьФорму("ОбщаяФорма.рнсФормаВыбораОбъектовМетаданных", ПараметрыФормы, ЭтаФорма,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	
КонецПроцедуры  
																						
&НаКлиенте
Процедура ФормаЗаполненияХранилищаПриИзменении(Элемент)
	
	ИспользоватьЗаполнениеХранилища = ЗначениеЗаполнено(Объект.ИмяФормыЗаполненияХранилища);
	
КонецПроцедуры    																					

&НаКлиенте
Процедура ИспользоватьКлючНастройкиПриИзменении(Элемент)  		
	
	ОбновитьТекстОписанияКлюча();
	
КонецПроцедуры

&НаКлиенте
Процедура ТекстОпаисаниеПолейКлючаНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;	
	
	Если Объект.ИспользоватьКлючНастройки Тогда    	
	
		Оповещение = Новый ОписаниеОповещения("НастройкиПолейКлюча_Завершение", ЭтотОбъект);
		НастройкаКлюча = Новый Массив;
		
		Для каждого Ит Из Объект.НастройкаКлюча Цикл
			
			ОписаниеПоляКлюча = Новый Структура;
			ОписаниеПоляКлюча.Вставить("ПолеКлюча", Ит.ПолеКлюча); 
			ОписаниеПоляКлюча.Вставить("Заголовок", Ит.Заголовок);
			
			НастройкаКлюча.Добавить(ОписаниеПоляКлюча);
			
		КонецЦикла;   
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("НастройкаКлюча", НастройкаКлюча);
		
		ОткрытьФорму("Справочник.рнсРазделыОбщихНастроек.Форма.ФормаНастройкиПолейКлюча", 
									ПараметрыФормы, ЭтаФорма,,,, Оповещение, РежимОткрытияОкнаФормы.Независимый);  
									
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ИспользоватьСекцииРазделаПриИзменении(Элемент)
	
	ОбновитьНастройкуСекцийРаздела();	
	
КонецПроцедуры    

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура НастройкиПолейКлюча_Завершение(Результат, ДополнительныеПараметры) Экспорт   
	                                    	
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		
		Объект.НастройкаКлюча.Очистить(); 		
		
		Для каждого Ит Из Результат Цикл   		
			ЗаполнитьЗначенияСвойств(Объект.НастройкаКлюча.Добавить(), Ит);	 		
		КонецЦикла;  
		
		ОбновитьТекстОписанияКлюча();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьТекстОписанияКлюча()
	
	Если Объект.ИспользоватьКлючНастройки Тогда  
		
		КоличествоПолейКлюча = Объект.НастройкаКлюча.Количество(); 	
		
		Если КоличествоПолейКлюча = 0 Тогда    
			ТекстОписанияПолейКлюча	= НСтр("ru = 'Дополнительные поля ключа не используются'");	
		Иначе         
			
			МасивТиповПолей 		= Новый Массив;
			ТекстШаблонаОписания 	= НСтр("ru = 'Поля ключа: %1'");
			
			Для каждого Ит Из Объект.НастройкаКлюча Цикл 				 
				МасивТиповПолей.Добавить(Ит.Заголовок);		
			КонецЦикла;
			
			ТекстОписанияПолейКлюча	= СтрШаблон(ТекстШаблонаОписания, СтрСоединить(МасивТиповПолей, ","));	
			
		КонецЕсли; 	
		
	Иначе   	
		ТекстОписанияПолейКлюча = НСтр("ru = 'Ключи не используются'");
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ОбновитьНастройкуСекцийРаздела()
	
	Элементы.СтраницаСекции.Видимость = Объект.ИспользоватьСекцииРаздела;
	
КонецПроцедуры 

&НаКлиенте
Процедура ВыборФормы_Завершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		Объект.ИмяФормыЗаполненияХранилища = Результат[0];
	Иначе    
		Если Результат <> Неопределено Тогда
			Объект.ИмяФормыЗаполненияХранилища = "";	
		КонецЕсли;  		
	КонецЕсли; 		
	
КонецПроцедуры 

#КонецОбласти  









