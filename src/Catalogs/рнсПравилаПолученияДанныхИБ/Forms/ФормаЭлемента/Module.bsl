&НаКлиенте
Процедура ПоказатьВопрос_Завершение(Результат, ПараметрыЗаписи) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ПараметрыЗаписи.Вставить("ВопросЗадан", Истина);
		Если Записать(ПараметрыЗаписи) И ПараметрыЗаписи.Свойство("Закрыть") Тогда
			Закрыть();
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры 

&НаКлиенте
Процедура РедактироватьСхему_Завершение(Результат, ДополнительныеПараметры) Экспорт
	        
	Если Результат <> Неопределено Тогда 
		ПрименитьИзмененияКСхемеКомпоновкиДанных(Результат);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти  

&НаСервере
Процедура ПрименитьИзмененияКСхемеКомпоновкиДанных(АдресНастроекСхемы)
	                                                    	
	Схема 							= ПолучитьИзВременногоХранилища(АдресСКД);
	НастройкиСхемы					= ПолучитьИзВременногоХранилища(АдресНастроекСхемы);
	НастройкиПоУмолчанию 			= Схема.НастройкиПоУмолчанию;	
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(Схема));
	КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиПоУмолчанию);
	КомпоновщикНастроек.Восстановить();
	
	Если ОбщегоНазначения.ЗначениеВСтрокуXML(КомпоновщикНастроек.ПолучитьНастройки()) <> ОбщегоНазначения.ЗначениеВСтрокуXML(НастройкиСхемы) Тогда 
		АдресНастроекСКД = АдресНастроекСхемы;
	КонецЕсли;
	
	НастроитьФормуПоСхемеКомпоновки(Схема, НастройкиСхемы);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройитьФорму()
	
	Элементы.ГруппаРежимРаботыПростой.Видимость 			= Ложь;
	Элементы.ГруппаРежимРаботыПоСпискуНастроек.Видимость 	= Ложь;
	Элементы.СтраницаРасширенныйРежим.Видимость 			= Ложь; 
	Элементы.НомерФиксированногоЗапросаВПакете.Видимость 	= Ложь;
	Элементы.ГруппаПараметрыРаботыПоСписку.Видимость        = Ложь;
	
	Если Объект.РежимРаботы = 0 Тогда
		Элементы.ГруппаРежимРаботыПростой.Видимость 			= Истина;
	ИначеЕсли Объект.РежимРаботы = 1 Тогда 
		
		Элементы.ГруппаПараметрыРаботыПоСписку.Видимость        = Истина;
		Элементы.ГруппаРежимРаботыПоСпискуНастроек.Видимость 	= Истина; 
		
		Если Объект.ВариантВыполнения = ПредопределенноеЗначение("Перечисление.рнсВариантВыполненияПравила.ЗапросСОбъединением") Тогда
			Элементы.НомерФиксированногоЗапросаВПакете.Видимость = Элементы.НомерФиксированногоЗапросаВПакете.МаксимальноеЗначение > 1;	
		КонецЕсли;  	
		
	ИначеЕсли Объект.РежимРаботы = 2 Тогда
		Элементы.СтраницаРасширенныйРежим.Видимость 			= Истина; 	
	КонецЕсли;	
	
КонецПроцедуры     

&НаСервереБезКонтекста
Функция ДвоичныеДанныеСхемы(Адрес, Идентификатор) 	
	
	Схема 		= ПолучитьИзВременногоХранилища(Адрес);
	ТекстXML 	= ОбщегоНазначения.ЗначениеВСтрокуXML(Схема);  	
	
	Возврат ПоместитьВоВременноеХранилище(ПолучитьДвоичныеДанныеИзСтроки(ТекстXML), Идентификатор);
	
КонецФункции  

&НаСервереБезКонтекста
Функция НеобходимоЗадатьВопрос(Адрес, Отказ)
	
	Схема = ПолучитьИзВременногоХранилища(Адрес);
	Если Схема = Неопределено Тогда  
		Отказ = Истина;	
		Возврат Неопределено;
	Иначе
		НастройкиКомпоновки = Схема.НастройкиПоУмолчанию;
		Возврат НЕ рнсСлужебный.ЕстьОбязательныеПараметры(НастройкиКомпоновки);		
	КонецЕсли; 
	
КонецФункции 

&НаСервере
Процедура НастроитьФормуПоСхемеКомпоновки(Схема, НастройкиКомпоновки)	
	
	Наборы 								= Схема.НаборыДанных;
	Объект.ИспользуетсяСписокОбъектов 	= Ложь;; 
	СписокПолейВыбора 					= Элементы.ИмяКолонкиРезультата.СписокВыбора;  
	
	СписокПолейВыбора.Очистить();   
	
	Для каждого Ит Из НастройкиКомпоновки.Выбор.Элементы Цикл 	
		ИмяПоля = Строка(Ит.Поле); 	
		СписокПолейВыбора.Добавить(ИмяПоля); 		
	КонецЦикла;   
	
	Для каждого Ит Из Схема.Параметры Цикл
		Если Ит.ДоступенСписокЗначений И НЕ Ит.ОграничениеИспользования Тогда  
			Объект.ИспользуетсяСписокОбъектов = Истина;
			Прервать;	
		КонецЕсли;	
	КонецЦикла; 	 
	
	Если Наборы.Количество() = 1 И ТипЗнч(Наборы[0]) = Тип("НаборДанныхЗапросСхемыКомпоновкиДанных") Тогда 
		
		ТекстЗапроса = Наборы[0].Запрос;
		СхемаЗапроса = Новый СхемаЗапроса;  
		
		СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса); 
		
		МаксимальноеЗначение = СхемаЗапроса.ПакетЗапросов.Количество(); 		
		
	Иначе  	
		МаксимальноеЗначение 											= 0;		 
		Элементы.ВариантВыполнения.Доступность 							= Ложь;
		Объект.ВариантВыполнения 										= Перечисления.рнсВариантВыполненияПравила.СхемаКомпоновки;			
	КонецЕсли; 
	
	Элементы.НомерФиксированногоЗапросаВПакете.МаксимальноеЗначение	= МаксимальноеЗначение; 
	Элементы.НомерФиксированногоЗапросаВПакете.Видимость = МаксимальноеЗначение > 1;
	
КонецПроцедуры

