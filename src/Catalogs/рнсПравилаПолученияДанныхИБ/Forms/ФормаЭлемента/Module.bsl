#Область ОбработчикиСобытийФормы   

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)   
		       	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда   
		Элементы.Код.Доступность = Истина;	
	Иначе	
		
		Элементы.НомерФиксированногоЗапросаВПакете.Видимость 			= Ложь; 
		Элементы.НомерФиксированногоЗапросаВПакете.МаксимальноеЗначение = 0;
		
		АдресСКД 			= ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);	
		АдресНастроекСКД 	= Неопределено;		
			
	КонецЕсли;         
	
	Элементы.ГруппаПараметрыРаботыПоСписку.Видимость 	= Объект.РежимРаботы = 1;   
	
	Если Метаданные.ОбщиеФормы.Найти("УпрощеннаяНастройкаСхемыКомпоновкиДанных") = Неопределено Тогда  
		ДоступнаФормаРедактированияСКД 					= Ложь;
		Элементы.РедактироватьЗагрузитьСхему.Заголовок  = НСтр("ru = 'Загрузить схему'");
	Иначе
		ДоступнаФормаРедактированияСКД 					= Истина; 
		Элементы.РедактироватьЗагрузитьСхему.Заголовок  = НСтр("ru = 'Редактировать'");
	КонецЕсли;     	  
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ДанныеСхемы = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Ссылка, "СхемаКомпоновкиДанных, ХранилищеНастроекКомпоновкиДанных");	
	Схема 		= ДанныеСхемы.СхемаКомпоновкиДанных.Получить();
	Настройки 	= ДанныеСхемы.ХранилищеНастроекКомпоновкиДанных.Получить();	
	АдресСКД 	= ПоместитьВоВременноеХранилище(Схема, Новый УникальныйИдентификатор);
	
	Если Схема <> Неопределено Тогда
		
		НастроитьФормуПоСхемеКомпоновки(Схема, Схема.НастройкиПоУмолчанию); 
		
		Если Настройки <> Неопределено Тогда
			АдресНастроекСКД = ПоместитьВоВременноеХранилище(Настройки, Новый УникальныйИдентификатор);
		КонецЕсли;
		
	КонецЕсли; 		
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	НастройитьФорму();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Модифицированность И НЕ ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗаписи, "ВопросЗадан", Ложь) Тогда
		
		ЗадатьВопрос = НеобходимоЗадатьВопрос(АдресСКД, Отказ);	
		
		Если Отказ Тогда         
			ТекстСообщения = НСтр("ru = 'Не задана схема компоновки данных'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);				
		Иначе 		
			Если ЗадатьВопрос Тогда
				
				Отказ 			= Истина;
				Оповещение 		= Новый ОписаниеОповещения("ПоказатьВопрос_Завершение", ЭтотОбъект, ПараметрыЗаписи);
				ТекстВопроса 	= НСтр("ru = 'Нет обязательных параметров в настройках. Продолжить?'");
				
				ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);			
				
			КонецЕсли; 		
		КонецЕсли;
	
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если НЕ ПустаяСтрока(АдресСКД) Тогда 
		ТекущийОбъект.СхемаКомпоновкиДанных =
			Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(АдресСКД));
	Иначе
		
		ТекущийОбъект.СхемаКомпоновкиДанных = Новый ХранилищеЗначения(Неопределено);

	КонецЕсли;
		
	Если НЕ ПустаяСтрока(АдресНастроекСКД) Тогда 
		
		ТекущийОбъект.ХранилищеНастроекКомпоновкиДанных =
			Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(АдресНастроекСКД));
			
	Иначе
			
		ТекущийОбъект.ХранилищеНастроекКомпоновкиДанных = Новый ХранилищеЗначения(Неопределено);
			
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура РежимРаботыПриИзменении(Элемент)
	
	НастройитьФорму();
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантВыполненияПриИзменении(Элемент)
	
	НастройитьФорму();	
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	
	ПараметрыЗаписи = Новый Структура;  
	ПараметрыЗаписи.Вставить("Закрыть", Истина);
	
	Если Записать(ПараметрыЗаписи) Тогда
		Закрыть();
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьЗагрузитьСхему(Команда)
	
	Если ДоступнаФормаРедактированияСКД Тогда
	                
		ИмяФормы									 = "ОбщаяФорма.УпрощеннаяНастройкаСхемыКомпоновкиДанных";
		ЗаголовокФормыНастройкиСхемыКомпоновкиДанных = НСтр("ru = 'Настройки ""%СКД%""'");
		ЗаголовокФормыНастройкиСхемыКомпоновкиДанных = СтрЗаменить(ЗаголовокФормыНастройкиСхемыКомпоновкиДанных, "%СКД%", Объект.Наименование); 	
		
		ПараметрыОткрытияФормы = Новый Структура;
		ПараметрыОткрытияФормы.Вставить("АдресСхемыКомпоновкиДанных", АдресСКД);
		ПараметрыОткрытияФормы.Вставить("АдресНастроекКомпоновкиДанных", ?(ПустаяСтрока(АдресНастроекСКД), Неопределено, АдресНастроекСКД));
		ПараметрыОткрытияФормы.Вставить("ИсточникШаблонов", Неопределено);
		ПараметрыОткрытияФормы.Вставить("Заголовок", ЗаголовокФормыНастройкиСхемыКомпоновкиДанных);
		ПараметрыОткрытияФормы.Вставить("НеПомещатьНастройкиВСхемуКомпоновкиДанных", Истина);
		ПараметрыОткрытияФормы.Вставить("НеНастраиватьУсловноеОформление", Истина);
		ПараметрыОткрытияФормы.Вставить("НеНастраиватьПорядок", Истина);
		ПараметрыОткрытияФормы.Вставить("НеНастраиватьВыбор", Истина);
		ПараметрыОткрытияФормы.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
		ПараметрыОткрытияФормы.Вставить("ИмяШаблонаСКД", "");
		ПараметрыОткрытияФормы.Вставить("ВозвращатьИмяТекущегоШаблонаСКД", Ложь);
		
		ОткрытьФорму(ИмяФормы,
			ПараметрыОткрытияФормы,,,,, 
			Новый ОписаниеОповещения("РедактироватьСхему_Завершение", ЭтотОбъект),
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
		
	Иначе  
		
		АдресФайла							= ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);		
		ОписаниеОповещения 					= Новый ОписаниеОповещения("ПрочитатьФайлСхемы_Завершение", ЭтотОбъект); 		
		ПараметрыДиалога 					= ФайловаяСистемаКлиент.ПараметрыЗагрузкиФайла(); 	
		ПараметрыДиалога.ИдентификаторФормы = УникальныйИдентификатор;		
		                                      
		ФайловаяСистемаКлиент.ЗагрузитьФайл(ОписаниеОповещения, ПараметрыДиалога,, АдресФайла); 
		
	КонецЕсли;
	
КонецПроцедуры   

&НаКлиенте
Процедура ВыгрузитьСхему(Команда)
	
	Если ЗначениеЗаполнено(Объект.Ссылка) И ЭтоАдресВременногоХранилища(АдресСКД) Тогда
		
		ДвоичныеДанные = ДвоичныеДанныеСхемы(АдресСКД, УникальныйИдентификатор);   
		
		Если ДвоичныеДанные <> Неопределено Тогда				
			
			ПараметрыСохранения 								= ФайловаяСистемаКлиент.ПараметрыСохраненияФайла();
			ПараметрыСохранения.Диалог.Заголовок 				= НСтр("ru = 'Выберите файл для сохранения'");
			ПараметрыСохранения.Диалог.МножественныйВыбор 		= Ложь;
			ПараметрыСохранения.Диалог.ПредварительныйПросмотр 	= Ложь;				
	
			ФайловаяСистемаКлиент.СохранитьФайл(Неопределено, ДвоичныеДанные, 
														Объект.Код, ПараметрыСохранения);			
			
		КонецЕсли; 		
			
	КонецЕсли; 		
	
КонецПроцедуры   

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции   

